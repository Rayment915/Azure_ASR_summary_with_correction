[{"sentence_id":"0","paragraph_id":"","lang":"zh_cn","content":"那请你先简单做个自我介绍吧。","start_time":960,"end_time":3160,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"1","paragraph_id":"","lang":"zh_cn","content":"好，面试官你好，我叫专业理论较为扎实，在去年的7月份进行过针对携程旅行APP用户体验优化的一个项目实操，一方面增进了自己对于产品简历、产品经理这一岗位的了解和熟悉，包括产品分析、用户调研、竞品分析、产品需求文档、PRD报告的撰写的流程，另外一方面也掌握了相关工具的使用，比如Axure、Xmind的一图图示等。","start_time":3760,"end_time":26560,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"2","paragraph_id":"","lang":"zh_cn","content":"之后在小鹏汽车的互联网中心进行了为期近5个月的产品实习。","start_time":26800,"end_time":30720,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"3","paragraph_id":"","lang":"zh_cn","content":"真正完成了从需求挖掘到功能设计再到功能落地的全过程，也根据对竞品的研究和分析以及用户访谈、用户调研的结果，输出了对新车型的亮点。","start_time":31180,"end_time":41980,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"4","paragraph_id":"","lang":"zh_cn","content":"产品规划，我是一个性格开朗、善于沟通、喜欢追求新鲜事物的人，而做产品是一个需要不断挖掘用户需求去迎合市场的工作，我觉得具有挑战，但是很有趣，因此希望能够在产品这条道路上一直走下去。","start_time":42020,"end_time":53940,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"5","paragraph_id":"","lang":"zh_cn","content":"我的自我介绍完毕，希望与您能有一个愉快的面试过程，请面试官提问。","start_time":54060,"end_time":58540,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"6","paragraph_id":"","lang":"zh_cn","content":"好的，谢谢你的介绍哈。","start_time":59540,"end_time":61780,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"7","paragraph_id":"","lang":"zh_cn","content":"那我刚刚也听到你在小朋友有一段经历哈。","start_time":61820,"end_time":64620,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"8","paragraph_id":"","lang":"zh_cn","content":"你说你做的需求挖掘、用户访谈到产品规划一整套流程，那我们一个一个来谈一下，就是，哎，那你们的需求一般有哪些来源？你是怎么挖掘的？","start_time":65170,"end_time":73650,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"9","paragraph_id":"","lang":"zh_cn","content":"需求大致是有三个来源，就是第一方面是那个，就是其他部门就给我们的反馈，譬如说市场部给的客诉反馈，然后运营他们给的一个就是用户数据分析。","start_time":75210,"end_time":89010,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"10","paragraph_id":"","lang":"zh_cn","content":"然后第二部分是就是那个一个自身去体验，自身去就是去上车去感受，比如说抬价和试车走查，然后就是去感受一些，就是那个就现在。","start_time":89730,"end_time":101010,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"11","paragraph_id":"","lang":"zh_cn","content":"做的不够好的点，然后第三个是老板的输入，对，就是可能是那个老板，他对未来的一个就是规划，然后到我们这里就是像拆分成小的需求来一个个实现。","start_time":101420,"end_time":112740,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"12","paragraph_id":"","lang":"zh_cn","content":"诶，那你们的需求你觉得最主要的一个来源什么？第一个哈。","start_time":113380,"end_time":118540,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"13","paragraph_id":"","lang":"zh_cn","content":"对，明白。","start_time":118740,"end_time":119740,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"14","paragraph_id":"","lang":"zh_cn","content":"诶，那你这三个渠道的需求优先级是怎么样的？你们之前有考虑过吗？","start_time":120100,"end_time":124140,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"15","paragraph_id":"","lang":"zh_cn","content":"其实就是并没有说这三个，就是他们之间就是那个相互的优先级，我们更多是考虑，就是从那个价值和成本这两个维度去考虑。","start_time":124900,"end_time":135780,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"16","paragraph_id":"","lang":"zh_cn","content":"就是价值大成本小的，大于价值大成本大的，然后大于价值小成本低，然后大于价值小成本高。","start_time":136300,"end_time":144620,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"17","paragraph_id":"","lang":"zh_cn","content":"对，那我们在工作中其实往往遇到这种情况，就是你自己有一套产品规划，对吧？","start_time":146100,"end_time":150180,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"18","paragraph_id":"","lang":"zh_cn","content":"那可能业务提需也好，老板提需也好，跟你原有的规划冲突了，那这个时候你觉得该怎么解决呢？","start_time":150380,"end_time":156820,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"19","paragraph_id":"","lang":"zh_cn","content":"就是我一般会就是那个，就是把我或者跟老板的理解，就是我这样理解你刚才说的这个问题，就是我跟老板的想法不一样。","start_time":157860,"end_time":168780,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"20","paragraph_id":"","lang":"zh_cn","content":"然后我会把这两个想法，就是他们，他们就是那个之间的优缺点，就是不会不是优缺点的，应该说是那个一些风险，然后还有一些好处，就是这两套方案就是都完整列下来，就是给老板，就是相当于是那个辅助老板决策，然后就是在老板决策之后，就是那个会第一时间去落实下去。","start_time":169180,"end_time":192300,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"21","paragraph_id":"","lang":"zh_cn","content":"然后如果就是那个在那个研发同学资源许可的情况下，会在就是上线之前进行一个AB测试。","start_time":192500,"end_time":199700,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"22","paragraph_id":"","lang":"zh_cn","content":"好的。","start_time":201110,"end_time":201430,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"23","paragraph_id":"","lang":"zh_cn","content":"这里打断一下，就是这个问题，就是抖音电商特别喜欢问面字节的同学特别注意，就是他经常喜欢问业务需求，和你原有的产品规划有冲突了，你该怎么解决？","start_time":202070,"end_time":214750,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"24","paragraph_id":"","lang":"zh_cn","content":"跟老板有冲突该怎么解决？","start_time":214870,"end_time":216190,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"25","paragraph_id":"","lang":"zh_cn","content":"而这个同学回答的我觉得还算ok，简单来讲就是把这个需求一视同仁，放在需求池里，还是用我原来的方法论去评估该什么优先级还是什么优先级，然后接下来继续提问哈。","start_time":216310,"end_time":230030,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"26","paragraph_id":"","lang":"zh_cn","content":"哎，那在你挖掘这些需求中，你可以介绍一个你最有成就感的需求吗？","start_time":230390,"end_time":234910,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"27","paragraph_id":"","lang":"zh_cn","content":"我最有成就感的需求应该是，就是您可以看我实习经历里的第五条，这个新车型亮点规划，我觉得我这是我做的最有意义的一件事情，然后简单说一下这个背景，是做二三年会上市的一款MPV车型，就是我们就是常见的那种商务车、面包车，就是那个新车型，就是除了对旧车型能力沿用之外，还需要结合车型特点去打磨出一些新的亮点和爆点，然后在那个亮点规划的前期，我做的主要工作是就是协助产品规划部去设计线上问卷和联系一个线下的经销商去深访。","start_time":236190,"end_time":270750,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"28","paragraph_id":"","lang":"zh_cn","content":"一个是装作预备车主去联系销售店就约时间去试驾和套话，便通过294个线上用户的调研和8个竞品经销商深访的结果，然后总结新车型目标用户关键特征以及目前依然存在的痛点。","start_time":271200,"end_time":288680,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"29","paragraph_id":"","lang":"zh_cn","content":"然后在这个总结中最突出的两个痛，最突出的痛点有两个，第一个是这个娱乐设备少，然后长途驾驶乘客无聊，尤其是孩子哭闹是绝对的痛点。","start_time":288920,"end_time":300320,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"30","paragraph_id":"","lang":"zh_cn","content":"第二个是就是那个MPV车型整体外观比较商务，科技感和这个智能化程度比较低，开出去可能更像司机。","start_time":300520,"end_time":308720,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"31","paragraph_id":"","lang":"zh_cn","content":"然后针对这两个痛点。","start_time":309110,"end_time":310230,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"32","paragraph_id":"","lang":"zh_cn","content":"就通过检索和思考想出了两个亮点，第一个是结合这款车已经有了小桌板和后排大屏这两个硬件设施，和百度教育开放平台达成合作，推出一个旅行课堂场景就减少孩子的哭闹，现在已经进入了商务洽谈阶段。","start_time":310510,"end_time":325630,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"33","paragraph_id":"","lang":"zh_cn","content":"第二个是通过手势识别，增加这个车辆的科技感。","start_time":325830,"end_time":329550,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"34","paragraph_id":"","lang":"zh_cn","content":"然后这手势识别又分两部分，第一部分是这个在座舱外使用手势控制电动门，就可以通过手势开门，然后座舱内新增手势识别功能，就驾驶者他可以通过手势来接挂电话，快速静音。","start_time":330430,"end_time":343870,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"35","paragraph_id":"","lang":"zh_cn","content":"然后第二、三排的乘客可以通过手势来控制后排屏的放下和开启。","start_time":344250,"end_time":348290,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"36","paragraph_id":"","lang":"zh_cn","content":"然后这个进展是目前已经有一个 demo 产出了，而这两个亮点都已经被产规定义成新车型重点宣传点和卖点，这个让我觉得很有成就感。","start_time":348570,"end_time":358130,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"37","paragraph_id":"","lang":"zh_cn","content":"嗯，好的，那咱们一个一个来说哈。","start_time":358570,"end_time":360490,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"38","paragraph_id":"","lang":"zh_cn","content":"先说你第一个亮点，就是你觉得旅行出行有教育这样一个场景，那你们有去调查过在人群中有多少人有晕车的比例？","start_time":360690,"end_time":369930,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"39","paragraph_id":"","lang":"zh_cn","content":"这晕车的比例是不是会很高？","start_time":370770,"end_time":372570,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"40","paragraph_id":"","lang":"zh_cn","content":"然后导致你这个场景是行不通的，有没有考虑这样的问题？","start_time":372570,"end_time":375810,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"41","paragraph_id":"","lang":"zh_cn","content":"是有考虑过这个风险的，然后就是像您刚才说的晕车这个也是一个，就是。","start_time":376490,"end_time":381530,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"42","paragraph_id":"","lang":"zh_cn","content":"说句实话，就是不管是什么样的车其实都会有，而且就是那个我们是有一个数据显示，如果说是就是一直盯着后排屏的话，他是会有一个就是更严重的一个晕车倾向的。","start_time":381970,"end_time":394450,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"43","paragraph_id":"","lang":"zh_cn","content":"就是那个然后我们这个解决方法，我们是就是在网上去检索了一些资料，然后就包括就是咨询了一些专家，就是专家给的建议就是说模拟一个，就是像我们在家里看电视，他永远不会那个晕车，也不会就是头晕这样子，然后就是去模拟一个那样的环境，就是一个类似于封闭，就是那个就是因为他晕车的那个原因，是那个就可能就是你后排屏在播放界面，然后就是，然后你，你还可以通过后。","start_time":395170,"end_time":425170,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"44","paragraph_id":"","lang":"zh_cn","content":"就是后排屏。","start_time":425290,"end_time":425930,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"45","paragraph_id":"","lang":"zh_cn","content":"下面就是那个车窗，然后就是看到那个一直在变动的一个一个风景，然后这个可能是晕车最主要的来源，就是我们就是跟专家就是那个交流之后就得到一个信息，然后在这里我们做了一点，就是说把那个就是扶手，把扶手板那个地方就是可以把它拉起来，就是就相当于一个一个小帷幕一样，就是这样就把后排屏那个整体的那个，就是那个亮暗度给降低了，然后就是那个能够就是有效的去缓解。","start_time":426440,"end_time":456480,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"46","paragraph_id":"","lang":"zh_cn","content":"就是用户晕车这么一个，这么一个就是情况吧。","start_time":456600,"end_time":461000,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"47","paragraph_id":"","lang":"zh_cn","content":"其实晕车我觉得主要有两方面，一个就是你刚说的这个户外场景和户内，这个就是车内和车外场景不一致，一个在动，一个不在动，另外一个我觉得是一个机械性的震动，你没有考虑这个因素吗？","start_time":462220,"end_time":475260,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"48","paragraph_id":"","lang":"zh_cn","content":"这个怎么消除呢？","start_time":475260,"end_time":476660,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"49","paragraph_id":"","lang":"zh_cn","content":"通过震动来导致我晕车，这个你们有没有考虑过？","start_time":476860,"end_time":480100,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"50","paragraph_id":"","lang":"zh_cn","content":"其实这个就是更多会是在硬件层次去考虑了，就是我们就是痛点是那个它不断在震动嘛？","start_time":480980,"end_time":488460,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"51","paragraph_id":"","lang":"zh_cn","content":"然后我们要做的事情就是要减震，这个具体怎么减震？","start_time":488500,"end_time":492140,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"52","paragraph_id":"","lang":"zh_cn","content":"我们是用了那个空气悬架，就是在车辆上，就是车的那个就是可能就通俗点说就是相当于。","start_time":492220,"end_time":499260,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"53","paragraph_id":"","lang":"zh_cn","content":"把车给支平了，就是就是那个就是相当于就是把减震措施做得很好，很完备，然后就是把这方面就是那个给那个降低影响了。","start_time":500160,"end_time":510680,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"54","paragraph_id":"","lang":"zh_cn","content":"明白明白。","start_time":513316,"end_time":514396,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"55","paragraph_id":"","lang":"zh_cn","content":"哎，刚刚其实有同学也在说哈，就是汽油味道也是一个晕车比较大的一个来源，这个你们有解决方案吗？","start_time":514516,"end_time":520076,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"56","paragraph_id":"","lang":"zh_cn","content":"其实就是这点，小鹏汽车它是做新能源汽车的，新能源汽车是没有那个汽油的。","start_time":522196,"end_time":528876,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"57","paragraph_id":"","lang":"zh_cn","content":"明白，明白。","start_time":529636,"end_time":530356,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"58","paragraph_id":"","lang":"zh_cn","content":"OK，好了。","start_time":530556,"end_time":531516,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"59","paragraph_id":"","lang":"zh_cn","content":"回到这个，你刚刚说这个亮点哈，就是你刚刚有说第二个亮点是手势识别，那我理解哈，就是现在我们看手机上也有这个手势识别，那其实它这个距离是非常有限的，那我不知道你在车里这个场景。","start_time":532516,"end_time":546876,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"60","paragraph_id":"","lang":"zh_cn","content":"它的这个距离是怎么样的？","start_time":547316,"end_time":548476,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"61","paragraph_id":"","lang":"zh_cn","content":"或者你觉得它的使用价值真的很高吗？","start_time":548636,"end_time":550436,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"62","paragraph_id":"","lang":"zh_cn","content":"你们怎么评估这个问题？","start_time":550436,"end_time":551636,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"63","paragraph_id":"","lang":"zh_cn","content":"就是我，我可以把这个问题拆解成两部分，就是第一个就是在车里，就是怎么去实现，就是那个第二个就是说这个价值在哪里？","start_time":553156,"end_time":561916,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"64","paragraph_id":"","lang":"zh_cn","content":"然后先说第一方面，就是这个，就是在车里怎么实现，就是您刚才说就是可能就是我们手机也可以实现，但手机是一个静态的一个实现，它是通过一个就是静态摄像头来实现的。","start_time":562156,"end_time":573316,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"65","paragraph_id":"","lang":"zh_cn","content":"但我们在车里采用的摄像头并不是一个静态摄像头，我们采用的是一个叫 TOF 摄像头，就是你可以理解成激光摄像头。","start_time":573396,"end_time":581036,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"66","paragraph_id":"","lang":"zh_cn","content":"这个东西就是它是会那个观测飞行光距离，就相当于就是它的精度和准度是非常大的，就是而且是已经有一些车，它们已经把这手势识别功能做上去了。","start_time":581406,"end_time":592526,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"67","paragraph_id":"","lang":"zh_cn","content":"对，然后就是已经有就是成功的先例在前面，就所以那个就是这点可行性还是比较高的。","start_time":593126,"end_time":601006,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"68","paragraph_id":"","lang":"zh_cn","content":"然后第二方面就是说你说的价值，就是刚才其实我也有提到，就是说我们在调查中最后得到结果就是说就是那个，就是它有一个痛点是科技感比较低嘛。","start_time":601126,"end_time":613326,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"69","paragraph_id":"","lang":"zh_cn","content":"其实手势识别这个东西是很酷的一件事情，就是而且我们是通过一个，就是在那个，就是我刚才说294个线上用户调研之后，我们就是又就是找了20位那个用户进行一个深度访谈。","start_time":613646,"end_time":627806,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"70","paragraph_id":"","lang":"zh_cn","content":"然后在这个访谈过程中，我们也有就是针对你刚才说的这个问题进行一个交流，就是说那个你觉得手势识别这个东西真的有用吗？","start_time":628486,"end_time":636126,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"71","paragraph_id":"","lang":"zh_cn","content":"然后我们得到结果是有13位用户是觉得是那个真的可以提升整个车的科技感，然后更愿意去就是为这个车辆去买单。对，这是我们得到数据。","start_time":636406,"end_time":645726,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"72","paragraph_id":"","lang":"zh_cn","content":"明白明白，OK，其实在用户调研的时候，就是我们很少去直接问用户，唉，你这个，我如果做了这个APP 你会不会用？","start_time":648356,"end_time":657756,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"73","paragraph_id":"","lang":"zh_cn","content":"如果做了这个功能你会不会用？","start_time":657756,"end_time":659196,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"74","paragraph_id":"","lang":"zh_cn","content":"其实我们做调研一个很根本的一个宗旨，就是不要让用户思考，因为用户说话可能在骗你，那你怎么去判断他说的是真话？","start_time":659236,"end_time":669356,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"75","paragraph_id":"","lang":"zh_cn","content":"或者说这个你怎么评估你们这个调研方式的一个合理性？","start_time":669356,"end_time":674316,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"76","paragraph_id":"","lang":"zh_cn","content":"对，这个你可以回答一下吗？","start_time":674396,"end_time":676276,"speaker":{"id":"1","name":"说话人1","type":101},"words":null,"channel_id":0},{"sentence_id":"77","paragraph_id":"","lang":"zh_cn","content":"其实就是这可能就是一个聊天的话术问题了。","start_time":677356,"end_time":681076,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"78","paragraph_id":"","lang":"zh_cn","content":"就是那个您刚才说的不能直接问，其实在那个交谈的过程中，我们也是没有直接去问他，这个就是说直接问他手势识别这东西就是有没有用，而是我们是，就是采用了一个循序渐进，就是首先是那个，就是先把那个用户的那个心理防线给它降低，就是先去问一些比较简单的问题，就譬如说你觉得MPV车型就是那个，就是您觉得最大痛点在哪里？","start_time":681406,"end_time":705286,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"79","paragraph_id":"","lang":"zh_cn","content":"其实有很多用户他会说就是科技感这个问题，然后就是我们在这个地方再去引出来。","start_time":705366,"end_time":710766,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"80","paragraph_id":"","lang":"zh_cn","content":"大概了解你的背景啊。","start_time":711086,"end_time":712406,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0},{"sentence_id":"81","paragraph_id":"","lang":"zh_cn","content":"好。","start_time":713326,"end_time":713686,"speaker":{"id":"2","name":"说话人2","type":101},"words":null,"channel_id":0}]